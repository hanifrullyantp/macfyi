# Copy to `.env` for local Vite / Tauri desktop app.
# Never commit real secrets.

# === SUPABASE (optional: activation, demo verify, public-config, telemetry) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: override public-config Edge Function URL
# VITE_PUBLIC_CONFIG_URL=https://your-project.supabase.co/functions/v1/public-config

# === LICENSE GATE ===
VITE_SKIP_LICENSE=true
# Production: point to deployed activate-license function
# VITE_LICENSE_ACTIVATE_URL=https://your-project.supabase.co/functions/v1/activate-license

# Dev-only: fixed test credentials (no DB)
# VITE_DEV_LICENSE_BYPASS=true
# VITE_DEV_LICENSE_EMAIL=xx
# VITE_DEV_LICENSE_KEY=xxx

# === MIDTRANS (landing checkout; server keys live in Supabase secrets) ===
# VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
# MIDTRANS_IS_PRODUCTION=false

# === SMTP / EMAIL (Supabase Edge Function secrets; not usually in Vite) ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=Macfyi <noreply@macfyi.com>
# OPS_ALERT_EMAIL=admin@macfyi.com

# === OPS ===
# CRON_SECRET=your-cron-secret

# === OPTIONAL TRACKING ===
# VITE_POSTHOG_KEY=
# VITE_GA_ID=
