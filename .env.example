# Copy to `.env` for local Vite / Tauri frontend.
# License gate: skip in dev, or point to deployed Supabase Edge Function.
VITE_SKIP_LICENSE=true
# VITE_LICENSE_ACTIVATE_URL=https://YOUR_PROJECT.supabase.co/functions/v1/activate-license

# Testing: show activation screen but accept email `xx` + key `xxx` without Supabase (no DB).
# VITE_DEV_LICENSE_BYPASS=true
# VITE_DEV_LICENSE_EMAIL=xx
# VITE_DEV_LICENSE_KEY=xxx
