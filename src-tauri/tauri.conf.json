{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Macfyi",
  "version": "0.2.0",
  "identifier": "com.macfyi.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "npm run build"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["macfyi"]
      }
    },
    "updater": {
      "active": false,
      "dialog": false,
      "pubkey": "",
      "endpoints": []
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Macfyi",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "AI-assisted Mac storage cleaner",
    "longDescription": "Macfyi scans safe user folders, categorizes clutter, and moves selected items to Trash.",
    "copyright": "Copyright © Macfyi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "resources": []
  }
}
