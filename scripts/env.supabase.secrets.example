# Salin ke scripts/env.supabase.secrets (file itu di-.gitignore).
# Pasang secret ke proyek terhubung:
#   supabase secrets set --env-file scripts/env.supabase.secrets
#
# Hapus baris yang tidak dipakai agar tidak menimpa secret lain dengan string kosong.

# --- SMTP (Edge: lisensi, komisi, alert penarikan) ---
# EMAIL_FROM untuk email lisensi: isi alamat email polos, contoh orders@domain.com
# (bukan format "Nama <email>" — nama pengirim diambil dari app_settings.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# OPS_ALERT_EMAIL=ops@domain.com,finance@domain.com

# SMTP_TLS=true
# SMTP_SECURE=true

# --- Midtrans ---
MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false

# --- Lynk.id (create checkout + webhook) ---
# LYNK_CREATE_URL=https://...
# LYNK_BEARER_TOKEN=
# atau merchant key / API key:
# LYNK_AUTH_MODE=x-api-key
# LYNK_API_KEY=
# LYNK_WEBHOOK_SECRET=
# LYNK_WEBHOOK_SIGNATURE_HEADER=x-lynk-signature

# --- Cron scheduled-ops ---
# CRON_SECRET=
