# Supabase — WAJIB sama nilainya antara Vercel dan local kalau Anda develop di laptop.
#
# • Vercel: Project → Settings → Environment Variables (Production / Preview — dan Development
#   juga jika Anda pakai preview dev di Vercel).
# • Local `npm run dev`: Vite TIDAK membaca env Vercel. Salin file ini:
#     cp .env.example .env.local
#   lalu isi nilai di `.env.local` (jangan commit file itu).
#
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Set only if you still deploy admin under macfyi.com/<segment> (legacy subpath):
# VITE_USE_ADMIN_SUBPATH=1
# Path segment (default admin → /admin/). Second console (folder macfyi-admin2): admin3 → /admin3/
# VITE_ADMIN_PATH_SEGMENT=admin3
# Dev port when subpath (landing proxies /admin → 5174, /admin3 → 5175):
# VITE_ADMIN_DEV_PORT=5175
