# Copy to `.env` and adjust. Vite only exposes vars prefixed with VITE_.

# Inline admin (defaults in code match demo; override in production)
# VITE_ADMIN_EMAIL=you@example.com
# VITE_ADMIN_PASSWORD=your-secret

# Optional: POST lead JSON on form submit (Supabase Edge, Zapier, etc.)
# VITE_LEAD_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/your-fn

# Midtrans Snap (Supabase Edge `create-midtrans-snap` + `payment-webhook`)
# Project URL and anon key from Supabase → Settings → API
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# Set to "false" to force fallback (Checkout URL di pengaturan admin)
# VITE_USE_MIDTRANS_SNAP=true
