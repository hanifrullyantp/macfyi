{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/admin",
      "destination": "https://admin.macfyi.com/",
      "permanent": true
    },
    {
      "source": "/admin/:path*",
      "destination": "https://admin.macfyi.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
